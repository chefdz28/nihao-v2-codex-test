# NiHao environment variables (Vite — must be prefixed with VITE_)

# Supabase
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Google Analytics 4 (optional). When set AND in a production build, GA4 loads
# and sends manual page views + a few safe events. Leave empty to disable GA
# entirely (e.g. in development). No personal data is ever sent.
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
